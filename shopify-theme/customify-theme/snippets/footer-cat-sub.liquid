{% comment %}
  body = sam HTML <li>вЂ¦ wewnД…trz ul. heading = tekst nagЕ‚Гіwka.
  Jeden link: bez h4 gdy nagЕ‚Гіwek i link znaczД… to samo (identycznie, Dlaв†”Prezent dla,
  DzieЕ„ Xв†”Prezent na DzieЕ„ X, Ељlub/Komuniaв†”prezent na Е›lub lub komun).
{% endcomment %}
{%- if body != blank -%}
  {%- assign _parts = body | split: 'class="footer-collections-link">' -%}
  {%- assign _n = _parts.size | minus: 1 -%}
  {%- assign _first = _parts[1] | split: '</a>' | first | strip_html | strip -%}
  {%- assign _h = heading | strip | downcase -%}
  {%- assign _f = _first | downcase -%}
  {%- assign _omit = false -%}
  {%- if _n == 1 and _first != blank -%}
    {%- if _f == _h -%}
      {%- assign _omit = true -%}
    {%- elsif _h contains 'dla ' -%}
      {%- assign _tail = _h | remove_first: 'dla ' | strip -%}
      {%- if _tail != blank -%}
        {%- assign _expect = 'prezent dla ' | append: _tail -%}
        {%- if _f == _expect -%}
          {%- assign _omit = true -%}
        {%- endif -%}
      {%- endif -%}
    {%- elsif _h contains 'dzieЕ„' -%}
      {%- assign _expect = 'prezent na ' | append: _h -%}
      {%- if _f == _expect -%}
        {%- assign _omit = true -%}
      {%- endif -%}
    {%- elsif _h contains 'Е›lub' and _h contains 'komun' -%}
      {%- if _f contains 'prezent na' and (_f contains 'Е›lub' or _f contains 'komun') -%}
        {%- assign _omit = true -%}
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}
<div class="footer-cat-sub">
  {%- unless _omit -%}<h4 class="footer-cat-subtitle">{{ heading }}</h4>{%- endunless -%}
  <ul class="footer-collections-list footer-collections-list--compact">{{ body }}</ul>
</div>
{%- endif -%}
