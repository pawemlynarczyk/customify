{%- comment -%}
  Wyjście: produkt:* | osoba:* | okazja:* — heurystyka z handle/tytułu; metafield customify.footer_kategoria opcjonalnie nadpisuje.
{%- endcomment -%}
{%- liquid
  assign mf = collection.metafields.customify.footer_kategoria.value | default: collection.metafields.customify.footer_kategoria | strip
  assign raw = collection.handle | append: ' ' | append: collection.title | downcase | replace: '-', ' ' | replace: '_', ' '
  assign fk = ''

  if mf != blank
    assign fk = mf
  endif

  if fk == blank
    if raw contains 'szklo' or raw contains 'szkle' or raw contains 'szkła' or raw contains 'na szkle'
      assign fk = 'produkt:szklo'
    elsif raw contains 'plotno' or raw contains 'płót' or raw contains 'plotnie' or raw contains 'plotna'
      assign fk = 'produkt:plotno'
    elsif raw contains 'plakat'
      assign fk = 'produkt:plakat'
    endif
  endif

  # na Dzień Babci / Dziadka — okazja; musi być przed „dla babci/dziadka”
  if fk == blank
    if raw contains 'dzień babci' or raw contains 'dzien babci' or raw contains 'na dzień babci' or raw contains 'na dzien babci' or raw contains 'dzien-babci'
      assign fk = 'okazja:dzien_babci'
    elsif raw contains 'dzień dziadka' or raw contains 'dzien dziadka' or raw contains 'na dzień dziadka' or raw contains 'na dzien dziadka' or raw contains 'dzien-dziadka'
      assign fk = 'okazja:dzien_dziadka'
    endif
  endif

  if fk == blank
    if raw contains 'dla-niej' or raw contains 'dla niej' or raw contains 'dla_niej' or raw contains 'dlaniej'
      assign fk = 'osoba:niej'
    elsif raw contains 'dla-zony' or raw contains 'dla zony' or raw contains 'dla żony'
      assign fk = 'osoba:zona'
    elsif raw contains 'dla babci' or raw contains 'dla-babci' or raw contains 'prezent dla babci'
      assign fk = 'osoba:babcia'
    elsif raw contains 'dziadkow' or raw contains 'dziadków' or raw contains 'dla dziadkow' or raw contains 'dla dziadków'
      assign fk = 'osoba:dziadkowie'
    elsif raw contains 'dla dziadka' or raw contains 'dla-dziadka'
      assign fk = 'osoba:dziadek'
    elsif raw contains 'kolegi z pracy' or raw contains 'kolegi-z-pracy'
      assign fk = 'osoba:kolega'
    elsif raw contains 'kolezanki z pracy' or raw contains 'koleżanki z pracy' or raw contains 'kolezanki-z-pracy'
      assign fk = 'osoba:kolezanka'
    elsif raw contains 'narzeczonego' or raw contains 'dla narzeczonego'
      assign fk = 'osoba:narzeczony'
    elsif raw contains 'narzeczonej' or raw contains 'dla narzeczonej'
      assign fk = 'osoba:narzeczona'
    elsif raw contains 'szefowej' or raw contains 'dla szefowej'
      assign fk = 'osoba:szefowa'
    elsif raw contains 'szefa' or raw contains 'dla szefa'
      assign fk = 'osoba:szef'
    elsif raw contains 'przyjaciolki' or raw contains 'przyjaciółki' or raw contains 'dla przyjaciolki' or raw contains 'dla przyjaciółki'
      assign fk = 'osoba:przyjaciolka'
    elsif raw contains 'rodzenstwa' or raw contains 'rodzeństwa' or raw contains 'dla rodzenstwa'
      assign fk = 'osoba:rodzenstwo'
    elsif raw contains 'malzenstwa' or raw contains 'małżeństwa' or raw contains 'dla malzenstwa' or raw contains 'malzenstwa'
      assign fk = 'osoba:malzenstwo'
    elsif raw contains 'milosnika zwierzat' or raw contains 'milosnik' or raw contains 'miłośnik' or raw contains 'milosnika' or raw contains 'milosnik zwierzat'
      assign fk = 'osoba:milosnik'
    endif
  endif

  if fk == blank
    if raw contains 'brata' or raw contains 'dla brata'
      assign fk = 'osoba:brat'
    elsif raw contains 'chlopaka' or raw contains 'chłopaka' or raw contains 'dla chlopaka' or raw contains 'dla chłopaka'
      assign fk = 'osoba:chlopak'
    elsif raw contains 'chlopca' or raw contains 'chłopca' or raw contains 'dla chlopca'
      assign fk = 'osoba:chlopiec'
    elsif raw contains 'dziewczynki' or raw contains 'dla dziewczynki'
      assign fk = 'osoba:dziewczynka'
    elsif raw contains 'dziewczyny' or raw contains 'dla dziewczyny'
      assign fk = 'osoba:dziewczyna'
    elsif raw contains 'dla mamy' or raw contains 'dla-mamy' or raw contains 'prezent dla mamy'
      assign fk = 'osoba:mama'
    elsif raw contains 'meza' or raw contains 'męża' or raw contains 'dla meza' or raw contains 'dla męża'
      assign fk = 'osoba:mez'
    elsif raw contains 'siostry' or raw contains 'dla siostry'
      assign fk = 'osoba:siostra'
    elsif raw contains 'taty' or raw contains 'dla taty'
      assign fk = 'osoba:tata'
    elsif raw contains 'dla-niego' or raw contains 'dla niego' or raw contains 'dla_niego'
      assign fk = 'osoba:niego'
    elsif raw contains 'dziecka' or raw contains 'dziecko' or raw contains 'dla dziecka'
      assign fk = 'osoba:dziecko'
    elsif raw contains 'rodzic' or raw contains 'dla rodzic'
      assign fk = 'osoba:rodzice'
    elsif raw contains 'dla pary' or raw contains 'dla-pary'
      assign fk = 'osoba:para'
    endif
  endif

  if fk == blank
    if raw contains 'urodzin'
      assign fk = 'okazja:urodziny'
    elsif raw contains 'wielkanoc'
      assign fk = 'okazja:wielkanoc'
    elsif raw contains 'walentyn'
      assign fk = 'okazja:walentynki'
    elsif raw contains 'rocznic'
      assign fk = 'okazja:rocznica'
    elsif raw contains 'imienin'
      assign fk = 'okazja:imieniny'
    elsif raw contains 'slub' or raw contains 'ślub' or raw contains 'wesele'
      assign fk = 'okazja:slub'
    elsif raw contains 'komunii' or raw contains 'komunia'
      assign fk = 'okazja:komunia'
    elsif raw contains 'dzien matki' or raw contains 'dzien-matki'
      assign fk = 'okazja:dzien_matki'
    elsif raw contains 'dzien ojca' or raw contains 'dzien-ojca'
      assign fk = 'okazja:dzien_ojca'
    elsif raw contains 'dzien kobiet' or raw contains 'dzien-kobiet'
      assign fk = 'okazja:dzien_kobiet'
    elsif raw contains 'swiat' or raw contains 'świąt' or raw contains 'swieta' or raw contains 'boze narodzenie' or raw contains 'gwiazd' or raw contains 'choink'
      assign fk = 'okazja:swieta'
    else
      assign fk = 'okazja:inne'
    endif
  endif
-%}
{{- fk -}}
