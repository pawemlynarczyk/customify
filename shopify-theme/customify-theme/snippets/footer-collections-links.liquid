{% comment %}
  Kategorie z heurystyki (handle + tytuł). Metafield customify.footer_kategoria opcjonalnie nadpisuje.
  Ukryte w stopce (tytuł dokładnie jak w adminie): SEO / duplikaty; m.in. „Prezent dla Niej” gdy jest osobna sekcja „Dla niej”.
{% endcomment %}
{%- assign footer_hidden_collection_titles = 'Obraz ze zdjęcia|Personalizowany prezent|Personalizowany prezent ze zdjęcia|Portret Pary ze zdjęcia|Prezent dla Pary|Dzień Dziadka|Dzień Babci|Dzień Matki|Dzień Ojca|Dzień Kobiet|Personalizowany prezent dla Niej|Prezent dla Niej|Personalizowany prezent dla Pary|Dla pary|Dla Pary|Personalizowany prezent dla Niego|Prezent dla Niego|Dla niego|Dla Niego' | split: '|' -%}
{%- assign footer_seen_title_norm = '' -%}
{% unless template == 'cart' %}
{%- liquid
  assign b_ps = ''
  assign b_pp = ''
  assign b_pl = ''
  assign b_on = ''
  assign b_oz = ''
  assign b_ob = ''
  assign b_od = ''
  assign b_brat = ''
  assign b_chlopak = ''
  assign b_chlopiec = ''
  assign b_dziadkow = ''
  assign b_dziewczynka = ''
  assign b_dziewczyna = ''
  assign b_kolega = ''
  assign b_kolezanka = ''
  assign b_mama = ''
  assign b_malz = ''
  assign b_milzw = ''
  assign b_mez = ''
  assign b_narzeczony = ''
  assign b_narzeczona = ''
  assign b_przyj = ''
  assign b_rodzen = ''
  assign b_siostra = ''
  assign b_szef = ''
  assign b_szefowa = ''
  assign b_tata = ''
  assign b_oni = ''
  assign b_odz = ''
  assign b_or = ''
  assign b_op = ''
  assign b_tesci = ''
  assign b_ou = ''
  assign b_os = ''
  assign b_ow = ''
  assign b_oro = ''
  assign b_oi = ''
  assign b_ok = ''
  assign b_odm = ''
  assign b_odo = ''
  assign b_odk = ''
  assign b_okbabci = ''
  assign b_okdziadka = ''
  assign b_owi = ''
  assign b_oi2 = ''
-%}
{% for collection in collections %}
  {% assign ct = collection.title | strip %}
  {% if footer_hidden_collection_titles contains ct %}
    {% continue %}
  {% endif %}
  {% assign ct_norm = ct | downcase %}
  {% assign ct_norm_key = '|' | append: ct_norm | append: '|' %}
  {% if footer_seen_title_norm contains ct_norm_key %}
    {% continue %}
  {% endif %}
  {% assign footer_seen_title_norm = footer_seen_title_norm | append: ct_norm_key %}
  {% assign h = collection.handle %}
  {% unless h == 'all' or h == 'see_also' or h == 'hidden' or h contains 'hidden' %}
    {% capture fk %}{% render 'footer-collection-category', collection: collection %}{% endcapture %}
    {% assign fk = fk | strip %}
    {% capture li %}<li class="footer-collections-item"><a href="{{ collection.url }}" class="footer-collections-link">{{ collection.title | escape }}</a></li>{% endcapture %}
    {% case fk %}
      {% when 'produkt:szklo' %}
        {% assign b_ps = b_ps | append: li %}
      {% when 'produkt:plotno' %}
        {% assign b_pp = b_pp | append: li %}
      {% when 'produkt:plakat' %}
        {% assign b_pl = b_pl | append: li %}
      {% when 'osoba:niej' %}
        {% assign b_on = b_on | append: li %}
      {% when 'osoba:zona' %}
        {% assign b_oz = b_oz | append: li %}
      {% when 'osoba:babcia' %}
        {% assign b_ob = b_ob | append: li %}
      {% when 'osoba:dziadek' %}
        {% assign b_od = b_od | append: li %}
      {% when 'osoba:brat' %}
        {% assign b_brat = b_brat | append: li %}
      {% when 'osoba:chlopak' %}
        {% assign b_chlopak = b_chlopak | append: li %}
      {% when 'osoba:chlopiec' %}
        {% assign b_chlopiec = b_chlopiec | append: li %}
      {% when 'osoba:dziadkowie' %}
        {% assign b_dziadkow = b_dziadkow | append: li %}
      {% when 'osoba:dziewczynka' %}
        {% assign b_dziewczynka = b_dziewczynka | append: li %}
      {% when 'osoba:dziewczyna' %}
        {% assign b_dziewczyna = b_dziewczyna | append: li %}
      {% when 'osoba:kolega' %}
        {% assign b_kolega = b_kolega | append: li %}
      {% when 'osoba:kolezanka' %}
        {% assign b_kolezanka = b_kolezanka | append: li %}
      {% when 'osoba:mama' %}
        {% assign b_mama = b_mama | append: li %}
      {% when 'osoba:malzenstwo' %}
        {% assign b_malz = b_malz | append: li %}
      {% when 'osoba:milosnik' %}
        {% assign b_milzw = b_milzw | append: li %}
      {% when 'osoba:mez' %}
        {% assign b_mez = b_mez | append: li %}
      {% when 'osoba:narzeczony' %}
        {% assign b_narzeczony = b_narzeczony | append: li %}
      {% when 'osoba:narzeczona' %}
        {% assign b_narzeczona = b_narzeczona | append: li %}
      {% when 'osoba:przyjaciolka' %}
        {% assign b_przyj = b_przyj | append: li %}
      {% when 'osoba:rodzenstwo' %}
        {% assign b_rodzen = b_rodzen | append: li %}
      {% when 'osoba:siostra' %}
        {% assign b_siostra = b_siostra | append: li %}
      {% when 'osoba:szef' %}
        {% assign b_szef = b_szef | append: li %}
      {% when 'osoba:szefowa' %}
        {% assign b_szefowa = b_szefowa | append: li %}
      {% when 'osoba:tata' %}
        {% assign b_tata = b_tata | append: li %}
      {% when 'osoba:niego' %}
        {% assign b_oni = b_oni | append: li %}
      {% when 'osoba:dziecko' %}
        {% assign b_odz = b_odz | append: li %}
      {% when 'osoba:rodzice' %}
        {% assign b_or = b_or | append: li %}
      {% when 'osoba:para' %}
        {% assign b_op = b_op | append: li %}
      {% when 'osoba:tesci' %}
        {% assign b_tesci = b_tesci | append: li %}
      {% when 'okazja:urodziny' %}
        {% assign b_ou = b_ou | append: li %}
      {% when 'okazja:swieta' %}
        {% assign b_os = b_os | append: li %}
      {% when 'okazja:walentynki' %}
        {% assign b_ow = b_ow | append: li %}
      {% when 'okazja:rocznica' %}
        {% assign b_oro = b_oro | append: li %}
      {% when 'okazja:imieniny' %}
        {% assign b_oi = b_oi | append: li %}
      {% when 'okazja:slub', 'okazja:komunia' %}
        {% assign b_ok = b_ok | append: li %}
      {% when 'okazja:dzien_matki' %}
        {% assign b_odm = b_odm | append: li %}
      {% when 'okazja:dzien_ojca' %}
        {% assign b_odo = b_odo | append: li %}
      {% when 'okazja:dzien_kobiet' %}
        {% assign b_odk = b_odk | append: li %}
      {% when 'okazja:dzien_babci' %}
        {% assign b_okbabci = b_okbabci | append: li %}
      {% when 'okazja:dzien_dziadka' %}
        {% assign b_okdziadka = b_okdziadka | append: li %}
      {% when 'okazja:wielkanoc' %}
        {% assign b_owi = b_owi | append: li %}
      {% when 'okazja:inne' %}
        {% assign b_oi2 = b_oi2 | append: li %}
    {% endcase %}
  {% endunless %}
{% endfor %}

<nav class="footer-collections-bar" aria-label="Kolekcje produktów">
  <div class="footer-collections-inner">

    <h2 class="footer-collections-heading">Kolekcje</h2>

    <div class="footer-cat-produkt-strip" aria-labelledby="footer-cat-produkt">
      <h3 class="footer-cat-title" id="footer-cat-produkt">Rodzaj produktu</h3>
      <div class="footer-cat-produkt-strip-inner">
        {% render 'footer-cat-sub', body: b_ps, heading: 'Na szkle' %}
        {% render 'footer-cat-sub', body: b_pp, heading: 'Na płótnie' %}
        {% render 'footer-cat-sub', body: b_pl, heading: 'Plakat' %}
      </div>
    </div>

    <div class="footer-collections-grid footer-collections-grid--four">
      <section class="footer-cat-block" aria-labelledby="footer-sub-niej">
        <h3 class="footer-cat-title" id="footer-sub-niej">Dla niej</h3>
        {% render 'footer-cat-sub', body: b_on, heading: 'Dla niej' %}
        {% render 'footer-cat-sub', body: b_oz, heading: 'Dla żony' %}
        {% render 'footer-cat-sub', body: b_mama, heading: 'Prezent dla mamy' %}
        {% render 'footer-cat-sub', body: b_ob, heading: 'Dla babci' %}
        {% render 'footer-cat-sub', body: b_kolezanka, heading: 'Prezent dla koleżanki z pracy' %}
        {% render 'footer-cat-sub', body: b_dziewczynka, heading: 'Prezent dla dziewczynki' %}
        {% render 'footer-cat-sub', body: b_dziewczyna, heading: 'Prezent dla dziewczyny' %}
        {% render 'footer-cat-sub', body: b_siostra, heading: 'Prezent dla siostry' %}
        {% render 'footer-cat-sub', body: b_narzeczona, heading: 'Prezent dla narzeczonej' %}
        {% render 'footer-cat-sub', body: b_przyj, heading: 'Prezent dla przyjaciółki' %}
        {% render 'footer-cat-sub', body: b_szefowa, heading: 'Prezent dla szefowej' %}
      </section>
      <section class="footer-cat-block" aria-labelledby="footer-sub-niego">
        <h3 class="footer-cat-title" id="footer-sub-niego">Dla niego</h3>
        {% render 'footer-cat-sub', body: b_oni, heading: 'Dla niego' %}
        {% render 'footer-cat-sub', body: b_brat, heading: 'Prezent dla brata' %}
        {% render 'footer-cat-sub', body: b_tata, heading: 'Prezent dla taty' %}
        {% render 'footer-cat-sub', body: b_mez, heading: 'Prezent dla męża' %}
        {% render 'footer-cat-sub', body: b_chlopak, heading: 'Prezent dla chłopaka' %}
        {% render 'footer-cat-sub', body: b_chlopiec, heading: 'Prezent dla chłopca' %}
        {% render 'footer-cat-sub', body: b_kolega, heading: 'Prezent dla kolegi z pracy' %}
        {% render 'footer-cat-sub', body: b_narzeczony, heading: 'Prezent dla narzeczonego' %}
        {% render 'footer-cat-sub', body: b_szef, heading: 'Prezent dla szefa' %}
        {% render 'footer-cat-sub', body: b_od, heading: 'Dla dziadka' %}
      </section>
      <section class="footer-cat-block" aria-labelledby="footer-sub-para">
        <h3 class="footer-cat-title" id="footer-sub-para">Dla pary</h3>
        {% render 'footer-cat-sub', body: b_dziadkow, heading: 'Prezent dla dziadków' %}
        {% render 'footer-cat-sub', body: b_or, heading: 'Dla rodziców' %}
        {% render 'footer-cat-sub', body: b_malz, heading: 'Prezent dla małżeństwa' %}
        {% render 'footer-cat-sub', body: b_op, heading: 'Dla pary' %}
        {% render 'footer-cat-sub', body: b_tesci, heading: 'Prezent dla teściów' %}
      </section>
      <section class="footer-cat-block" aria-labelledby="footer-cat-okazja">
        <h3 class="footer-cat-title" id="footer-cat-okazja">Na okazję</h3>
        {% render 'footer-cat-sub', body: b_ou, heading: 'Urodziny' %}
        {% render 'footer-cat-sub', body: b_os, heading: 'Święta' %}
        {% render 'footer-cat-sub', body: b_ow, heading: 'Walentynki' %}
        {% render 'footer-cat-sub', body: b_oro, heading: 'Rocznica' %}
        {% render 'footer-cat-sub', body: b_oi, heading: 'Imieniny' %}
        {% render 'footer-cat-sub', body: b_ok, heading: 'Ślub / Komunia' %}
        {% render 'footer-cat-sub', body: b_odm, heading: 'Dzień Matki' %}
        {% render 'footer-cat-sub', body: b_odo, heading: 'Dzień Ojca' %}
        {% render 'footer-cat-sub', body: b_odk, heading: 'Dzień Kobiet' %}
        {% render 'footer-cat-sub', body: b_okbabci, heading: 'Dzień Babci' %}
        {% render 'footer-cat-sub', body: b_okdziadka, heading: 'Dzień Dziadka' %}
        {% render 'footer-cat-sub', body: b_owi, heading: 'Wielkanoc' %}
        {% render 'footer-cat-sub', body: b_oi2, heading: 'Inne okazje' %}
      </section>
    </div>

    {% if b_odz != blank or b_rodzen != blank or b_milzw != blank %}
    <div class="footer-cat-dla-kogo-extra">
      {% render 'footer-cat-sub', body: b_odz, heading: 'Dla dziecka' %}
      {% render 'footer-cat-sub', body: b_rodzen, heading: 'Prezent dla rodzeństwa' %}
      {% render 'footer-cat-sub', body: b_milzw, heading: 'Prezent dla miłośnika zwierząt' %}
    </div>
    {% endif %}
  </div>
</nav>
{% endunless %}
