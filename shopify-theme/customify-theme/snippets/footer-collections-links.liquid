{% comment %}
  Kategorie z heurystyki (handle + tytuł). Metafield customify.footer_kategoria opcjonalnie nadpisuje.
  Ukryte w stopce (tytuł dokładnie jak w adminie):
{% endcomment %}
{%- assign footer_hidden_collection_titles = 'Obraz ze zdjęcia|Personalizowany prezent|Personalizowany prezent ze zdjęcia|Portret Pary ze zdjęcia|Prezent dla Pary' | split: '|' -%}
{%- assign footer_seen_title_norm = '' -%}
{% unless template == 'cart' %}
{%- liquid
  assign b_ps = ''
  assign b_pp = ''
  assign b_pl = ''
  assign b_on = ''
  assign b_oz = ''
  assign b_ob = ''
  assign b_od = ''
  assign b_brat = ''
  assign b_chlopak = ''
  assign b_chlopiec = ''
  assign b_dziadkow = ''
  assign b_dziewczynka = ''
  assign b_dziewczyna = ''
  assign b_kolega = ''
  assign b_kolezanka = ''
  assign b_mama = ''
  assign b_malz = ''
  assign b_milzw = ''
  assign b_mez = ''
  assign b_narzeczony = ''
  assign b_narzeczona = ''
  assign b_przyj = ''
  assign b_rodzen = ''
  assign b_siostra = ''
  assign b_szef = ''
  assign b_szefowa = ''
  assign b_tata = ''
  assign b_oni = ''
  assign b_odz = ''
  assign b_or = ''
  assign b_op = ''
  assign b_ou = ''
  assign b_os = ''
  assign b_ow = ''
  assign b_oro = ''
  assign b_oi = ''
  assign b_ok = ''
  assign b_odm = ''
  assign b_odo = ''
  assign b_odk = ''
  assign b_okbabci = ''
  assign b_okdziadka = ''
  assign b_owi = ''
  assign b_oi2 = ''
-%}
{% for collection in collections %}
  {% assign ct = collection.title | strip %}
  {% if footer_hidden_collection_titles contains ct %}
    {% continue %}
  {% endif %}
  {% assign ct_norm = ct | downcase %}
  {% assign ct_norm_key = '|' | append: ct_norm | append: '|' %}
  {% if footer_seen_title_norm contains ct_norm_key %}
    {% continue %}
  {% endif %}
  {% assign footer_seen_title_norm = footer_seen_title_norm | append: ct_norm_key %}
  {% assign h = collection.handle %}
  {% unless h == 'all' or h == 'see_also' or h == 'hidden' or h contains 'hidden' %}
    {% capture fk %}{% render 'footer-collection-category', collection: collection %}{% endcapture %}
    {% assign fk = fk | strip %}
    {% capture li %}<li class="footer-collections-item"><a href="{{ collection.url }}" class="footer-collections-link">{{ collection.title | escape }}</a></li>{% endcapture %}
    {% case fk %}
      {% when 'produkt:szklo' %}
        {% assign b_ps = b_ps | append: li %}
      {% when 'produkt:plotno' %}
        {% assign b_pp = b_pp | append: li %}
      {% when 'produkt:plakat' %}
        {% assign b_pl = b_pl | append: li %}
      {% when 'osoba:niej' %}
        {% assign b_on = b_on | append: li %}
      {% when 'osoba:zona' %}
        {% assign b_oz = b_oz | append: li %}
      {% when 'osoba:babcia' %}
        {% assign b_ob = b_ob | append: li %}
      {% when 'osoba:dziadek' %}
        {% assign b_od = b_od | append: li %}
      {% when 'osoba:brat' %}
        {% assign b_brat = b_brat | append: li %}
      {% when 'osoba:chlopak' %}
        {% assign b_chlopak = b_chlopak | append: li %}
      {% when 'osoba:chlopiec' %}
        {% assign b_chlopiec = b_chlopiec | append: li %}
      {% when 'osoba:dziadkowie' %}
        {% assign b_dziadkow = b_dziadkow | append: li %}
      {% when 'osoba:dziewczynka' %}
        {% assign b_dziewczynka = b_dziewczynka | append: li %}
      {% when 'osoba:dziewczyna' %}
        {% assign b_dziewczyna = b_dziewczyna | append: li %}
      {% when 'osoba:kolega' %}
        {% assign b_kolega = b_kolega | append: li %}
      {% when 'osoba:kolezanka' %}
        {% assign b_kolezanka = b_kolezanka | append: li %}
      {% when 'osoba:mama' %}
        {% assign b_mama = b_mama | append: li %}
      {% when 'osoba:malzenstwo' %}
        {% assign b_malz = b_malz | append: li %}
      {% when 'osoba:milosnik' %}
        {% assign b_milzw = b_milzw | append: li %}
      {% when 'osoba:mez' %}
        {% assign b_mez = b_mez | append: li %}
      {% when 'osoba:narzeczony' %}
        {% assign b_narzeczony = b_narzeczony | append: li %}
      {% when 'osoba:narzeczona' %}
        {% assign b_narzeczona = b_narzeczona | append: li %}
      {% when 'osoba:przyjaciolka' %}
        {% assign b_przyj = b_przyj | append: li %}
      {% when 'osoba:rodzenstwo' %}
        {% assign b_rodzen = b_rodzen | append: li %}
      {% when 'osoba:siostra' %}
        {% assign b_siostra = b_siostra | append: li %}
      {% when 'osoba:szef' %}
        {% assign b_szef = b_szef | append: li %}
      {% when 'osoba:szefowa' %}
        {% assign b_szefowa = b_szefowa | append: li %}
      {% when 'osoba:tata' %}
        {% assign b_tata = b_tata | append: li %}
      {% when 'osoba:niego' %}
        {% assign b_oni = b_oni | append: li %}
      {% when 'osoba:dziecko' %}
        {% assign b_odz = b_odz | append: li %}
      {% when 'osoba:rodzice' %}
        {% assign b_or = b_or | append: li %}
      {% when 'osoba:para' %}
        {% assign b_op = b_op | append: li %}
      {% when 'okazja:urodziny' %}
        {% assign b_ou = b_ou | append: li %}
      {% when 'okazja:swieta' %}
        {% assign b_os = b_os | append: li %}
      {% when 'okazja:walentynki' %}
        {% assign b_ow = b_ow | append: li %}
      {% when 'okazja:rocznica' %}
        {% assign b_oro = b_oro | append: li %}
      {% when 'okazja:imieniny' %}
        {% assign b_oi = b_oi | append: li %}
      {% when 'okazja:slub', 'okazja:komunia' %}
        {% assign b_ok = b_ok | append: li %}
      {% when 'okazja:dzien_matki' %}
        {% assign b_odm = b_odm | append: li %}
      {% when 'okazja:dzien_ojca' %}
        {% assign b_odo = b_odo | append: li %}
      {% when 'okazja:dzien_kobiet' %}
        {% assign b_odk = b_odk | append: li %}
      {% when 'okazja:dzien_babci' %}
        {% assign b_okbabci = b_okbabci | append: li %}
      {% when 'okazja:dzien_dziadka' %}
        {% assign b_okdziadka = b_okdziadka | append: li %}
      {% when 'okazja:wielkanoc' %}
        {% assign b_owi = b_owi | append: li %}
      {% when 'okazja:inne' %}
        {% assign b_oi2 = b_oi2 | append: li %}
    {% endcase %}
  {% endunless %}
{% endfor %}

<nav class="footer-collections-bar" aria-label="Kolekcje produktów">
  <div class="footer-collections-inner">

    <h2 class="footer-collections-heading">Kolekcje</h2>

    <div class="footer-collections-grid">

      <section class="footer-cat-block" aria-labelledby="footer-cat-produkt">
        <h3 class="footer-cat-title" id="footer-cat-produkt">Rodzaj produktu</h3>
        {% if b_ps != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Na szkle</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_ps }}</ul></div>
        {% endif %}
        {% if b_pp != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Na płótnie</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_pp }}</ul></div>
        {% endif %}
        {% if b_pl != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Plakat</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_pl }}</ul></div>
        {% endif %}
      </section>

      <section class="footer-cat-block footer-cat-block--wide" aria-labelledby="footer-cat-osoba">
        <h3 class="footer-cat-title" id="footer-cat-osoba">Dla kogo</h3>
        <div class="footer-cat-dla-kogo-grid">
        {% if b_on != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Dla niej</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_on }}</ul></div>
        {% endif %}
        {% if b_oz != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Dla żony</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_oz }}</ul></div>
        {% endif %}
        {% if b_ob != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Dla babci</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_ob }}</ul></div>
        {% endif %}
        {% if b_od != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Dla dziadka</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_od }}</ul></div>
        {% endif %}
        {% if b_brat != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla brata</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_brat }}</ul></div>
        {% endif %}
        {% if b_chlopak != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla chłopaka</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_chlopak }}</ul></div>
        {% endif %}
        {% if b_chlopiec != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla chłopca</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_chlopiec }}</ul></div>
        {% endif %}
        {% if b_dziadkow != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla dziadków</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_dziadkow }}</ul></div>
        {% endif %}
        {% if b_dziewczynka != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla dziewczynki</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_dziewczynka }}</ul></div>
        {% endif %}
        {% if b_dziewczyna != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla dziewczyny</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_dziewczyna }}</ul></div>
        {% endif %}
        {% if b_kolega != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla kolegi z pracy</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_kolega }}</ul></div>
        {% endif %}
        {% if b_kolezanka != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla koleżanki z pracy</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_kolezanka }}</ul></div>
        {% endif %}
        {% if b_mama != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla mamy</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_mama }}</ul></div>
        {% endif %}
        {% if b_malz != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla małżeństwa</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_malz }}</ul></div>
        {% endif %}
        {% if b_milzw != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla miłośnika zwierząt</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_milzw }}</ul></div>
        {% endif %}
        {% if b_mez != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla męża</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_mez }}</ul></div>
        {% endif %}
        {% if b_narzeczony != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla narzeczonego</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_narzeczony }}</ul></div>
        {% endif %}
        {% if b_narzeczona != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla narzeczonej</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_narzeczona }}</ul></div>
        {% endif %}
        {% if b_przyj != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla przyjaciółki</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_przyj }}</ul></div>
        {% endif %}
        {% if b_rodzen != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla rodzeństwa</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_rodzen }}</ul></div>
        {% endif %}
        {% if b_siostra != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla siostry</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_siostra }}</ul></div>
        {% endif %}
        {% if b_szef != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla szefa</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_szef }}</ul></div>
        {% endif %}
        {% if b_szefowa != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla szefowej</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_szefowa }}</ul></div>
        {% endif %}
        {% if b_tata != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Prezent dla taty</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_tata }}</ul></div>
        {% endif %}
        {% if b_oni != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Dla niego</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_oni }}</ul></div>
        {% endif %}
        {% if b_odz != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Dla dziecka</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_odz }}</ul></div>
        {% endif %}
        {% if b_or != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Dla rodziców</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_or }}</ul></div>
        {% endif %}
        {% if b_op != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Dla pary</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_op }}</ul></div>
        {% endif %}
        </div>
      </section>

      <section class="footer-cat-block" aria-labelledby="footer-cat-okazja">
        <h3 class="footer-cat-title" id="footer-cat-okazja">Na okazję</h3>
        {% if b_ou != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Urodziny</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_ou }}</ul></div>
        {% endif %}
        {% if b_os != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Święta</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_os }}</ul></div>
        {% endif %}
        {% if b_ow != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Walentynki</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_ow }}</ul></div>
        {% endif %}
        {% if b_oro != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Rocznica</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_oro }}</ul></div>
        {% endif %}
        {% if b_oi != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Imieniny</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_oi }}</ul></div>
        {% endif %}
        {% if b_ok != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Ślub / Komunia</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_ok }}</ul></div>
        {% endif %}
        {% if b_odm != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Dzień Matki</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_odm }}</ul></div>
        {% endif %}
        {% if b_odo != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Dzień Ojca</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_odo }}</ul></div>
        {% endif %}
        {% if b_odk != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Dzień Kobiet</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_odk }}</ul></div>
        {% endif %}
        {% if b_okbabci != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Dzień Babci</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_okbabci }}</ul></div>
        {% endif %}
        {% if b_okdziadka != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Dzień Dziadka</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_okdziadka }}</ul></div>
        {% endif %}
        {% if b_owi != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Wielkanoc</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_owi }}</ul></div>
        {% endif %}
        {% if b_oi2 != blank %}
          <div class="footer-cat-sub"><h4 class="footer-cat-subtitle">Inne okazje</h4><ul class="footer-collections-list footer-collections-list--compact">{{ b_oi2 }}</ul></div>
        {% endif %}
      </section>

    </div>
  </div>
</nav>
{% endunless %}
