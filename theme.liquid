<script>
(function(){
  function move() {
    var section = document.querySelector('[id^="ProductInformation-"]');
    if (!section) return;
    var col = section.classList.contains('product-details') ? section : section.querySelector('.product-details');
    if (!col) { var g = section.querySelector('[data-product-grid-content]'); col = g && g.children[1]; }
    var buyForm = section.querySelector('[id^="BuyButtons-ProductForm-template--"]');
    if (!col || !buyForm) return;
    var block = buyForm;
    while (block.parentElement && block.parentElement !== col) block = block.parentElement;
    if (block.parentElement === col) col.appendChild(block);
  }
  function setupKupButton() {
    var form = document.querySelector('[id^="BuyButtons-ProductForm-template--"]');
    if (!form || form.dataset.simpleProductDone) return;
    var submitBtn = form.querySelector('button[id^="BuyButtons-ProductSubmitButton"]');
    if (submitBtn) submitBtn.textContent = 'Kup';
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var btn = form.querySelector('button[type="submit"]');
      if (btn) { btn.disabled = true; btn.textContent = '…'; }
      var fid = form.querySelector('input[name="id"]');
      var qty = form.querySelector('input[name="quantity"]');
      var variantId = fid ? fid.value : '';
      var quantity = (qty && parseInt(qty.value, 10)) || 1;
      var body = JSON.stringify({ items: [ { id: parseInt(variantId, 10), quantity: quantity } ] });
      fetch((window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root + 'cart/add.js' : '/cart/add.js', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' }, body: body }).then(function(r){ return r.json().then(function(data){ return { ok: r.ok, data: data }; }); }).then(function(res) {
        if (!res.ok && res.data && res.data.description) { if (btn) { btn.disabled = false; btn.textContent = 'Kup'; } alert(res.data.description); return; }
        window.location.href = '/cart';
      }).catch(function() { if (btn) { btn.disabled = false; btn.textContent = 'Kup'; } window.location.href = '/cart'; });
    });
    form.dataset.simpleProductDone = '1';
  }
  function run() { move(); setupKupButton(); }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', function(){ run(); setTimeout(run,200); setTimeout(run,600); });
  else { run(); setTimeout(run,200); setTimeout(run,600); }
})();
</script>
{% endif %}

